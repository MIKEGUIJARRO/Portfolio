<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="/css/styles.css" rel="stylesheet">
    <link href="/main/bundle.css" rel="stylesheet">
    <meta name="description"
        content="Hola! 👋 My name is Mike Guijarro and I am a passionate software engineer that have experience in the frontend, backend and mobile development.">
    <title>{{title}}</title>
</head>

{{!-- https://atomiks.github.io/tippyjs/v6/getting-started/ --}}

<body class="overflow-x-hidden">
    {{!-- Nav container --}}
    {{> navigation}}
    {{!-- Body container --}}
    <div class="max-w-screen-lg mx-auto px-10">
        {{{body}}}
    </div>
    {{!-- Footer --}}
    {{> footer}}
    <script src="/main/bundle.js" defer></script>

    {{#if loadAddElement}}
    <script src="/addElement/bundle.js"></script>
    {{/if}}


</body>

</html>