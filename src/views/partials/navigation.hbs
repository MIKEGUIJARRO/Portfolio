<div class="flex justify-between py-8">
    {{#if navUser }}
    <ul class="flex flex-row space-x-4">
        <p>Resume: {{url}}</p>
        <li><a href="{{resume.url}}" target="_blank" class="btn-square-rounded">Resume</a>
        </li>
        <li><a href="#" class="btn-square-rounded">Transcript</a>
        </li>
    </ul>

    <ul class="flex flex-row space-x-8">
        <li><a href="#about" class="grayscale-title">About</a></li>
        <li><a href="#experience" class="grayscale-title">Experience</a></li>
        <li><a href="#work" class="grayscale-title">Work</a></li>
        <li><a href="#contact" class="grayscale-title">Contact</a></li>
    </ul>
    {{else if dashboardNav}}
    <ul class="flex flex-row space-x-8">
        <li><a href="/add-resume" class="btn-square-rounded">Add Resume</a></li>
        <li><a href="#" class="btn-square-rounded">Add Transcript</a></li>
    </ul>
    <ul class="flex flex-row space-x-8">
        <li><a href="/" class="btn-main-outline">Home</a></li>
        <li><a href="#" class="btn-main-outline">Logout</a></li>
    </ul>
    {{else if navError}}
    <ul class="flex flex-row space-x-8">
        <li><a href="/" class="btn-main">Home</a></li>
    </ul>
    {{/if}}
</div>